{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PP1",
  "version": "0.1.0",
  "identifier": "com.pp1.desktop",
  "build": {
    "beforeDevCommand": "npm run dev:web -- --host 127.0.0.1 --port 5173",
    "beforeBuildCommand": "npm run build:desktop-web",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "PP1",
        "width": 1440,
        "height": 960,
        "minWidth": 1120,
        "minHeight": 720,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        "default"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  }
}
