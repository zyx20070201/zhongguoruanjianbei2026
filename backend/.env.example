PORT=3001
# HOST defaults to 127.0.0.1 for local development.
# Set HOST=0.0.0.0 only when you intentionally need LAN/container access.
# HOST=127.0.0.1

# Preferred production document preview provider
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# Optional overrides
# CLOUDCONVERT_API_BASE_URL=https://api.cloudconvert.com/v2
# CLOUDCONVERT_SYNC_API_BASE_URL=https://sync.api.cloudconvert.com/v2

# Optional local fallback if you still want on-machine conversion
# SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# DeepSeek AI
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Context retrieval stack: Qdrant + bge-m3 + bge-reranker-v2-m3
QDRANT_BASE_URL=http://localhost:6333
QDRANT_COLLECTION=workspace_knowledge_chunks
QDRANT_DISTANCE=Cosine
EMBEDDING_BASE_URL=http://localhost:8081
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
RERANKER_BASE_URL=http://localhost:8082
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CONTEXT_LEXICAL_TOP_K=40
CONTEXT_VECTOR_TOP_K=40
CONTEXT_RERANK_TOP_K=24
