PORT=3001
# HOST defaults to 127.0.0.1 for local development.
# Set HOST=0.0.0.0 only when you intentionally need LAN/container access.
# HOST=127.0.0.1

# Auth/session hardening
# AUTH_SESSION_SECRET=replace-with-a-long-random-secret
# AUTH_SESSION_TTL_MS=604800000
# AUTH_COOKIE_NAME=pp1_session
# APP_BASE_URL=http://localhost:5173
# CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# EMAIL_VERIFICATION_TTL_MS=86400000
# PASSWORD_RESET_TTL_MS=1800000

# Preferred production document preview provider
CLOUDCONVERT_API_KEY=your_cloudconvert_api_key

# Optional overrides
# CLOUDCONVERT_API_BASE_URL=https://api.cloudconvert.com/v2
# CLOUDCONVERT_SYNC_API_BASE_URL=https://sync.api.cloudconvert.com/v2

# Optional local fallback if you still want on-machine conversion
# SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice

# DeepSeek AI
# DEEPSEEK_API_KEY=your_deepseek_api_key
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-chat

# Workbench AI chat provider.
# Defaults to OpenAI. Set AI_CHAT_PROVIDER=deepseek|openai|gemini|claude to choose the default adapter.
# AI_CHAT_PROVIDER=openai
# AI_DEFAULT_PROVIDER=openai
# Optional per-agent overrides. If unset, AI_DEFAULT_PROVIDER then AI_CHAT_PROVIDER is used.
# AI_STUDIO_PROVIDER=openai
# AI_PLANNER_PROVIDER=openai
# AI_LEARNING_PROVIDER=openai
# AI_MEMORY_PROVIDER=openai
# AI_FLASHCARD_PROVIDER=openai
# AI_QUIZ_PROVIDER=openai
# AI_RESOURCE_PROVIDER=openai
# AI_VIDEO_PROVIDER=openai
# AI_TABLE_PROVIDER=openai
# Optional per-agent model overrides follow the same names, for example:
# AI_STUDIO_MODEL=claude-sonnet-4-5
# AI_PLANNER_MODEL=gemini-2.5-pro
# AI_MEMORY_MODEL=gpt-5.4
# OPENAI_API_KEY=your_openai_api_key
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_MODE=responses
# OPENAI_MODEL=gpt-5.4
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com
# GEMINI_MODEL=gemini-2.5-flash
# ANTHROPIC_API_KEY=your_anthropic_api_key
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# CLAUDE_MODEL=claude-sonnet-4-5

# Context retrieval stack: Qdrant + bge-m3 + bge-reranker-v2-m3
QDRANT_BASE_URL=http://localhost:6333
QDRANT_COLLECTION=workspace_knowledge_chunks
QDRANT_DISTANCE=Cosine
EMBEDDING_BASE_URL=http://localhost:8081
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_DIMENSION=1024
RERANKER_BASE_URL=http://localhost:8082
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
CONTEXT_LEXICAL_TOP_K=40
CONTEXT_VECTOR_TOP_K=40
CONTEXT_RERANK_TOP_K=24

# Workbench video intelligence
# VIDEO_ANALYSIS_PROVIDER=local
# VIDEO_ANALYSIS_PROVIDER=autodl
# VIDEO_ANALYSIS_BASE_URL=http://127.0.0.1:18100
# VIDEO_ANALYSIS_API_KEY=change-me
# VIDEO_WHISPER_MODEL=base
# VIDEO_ANALYSIS_MAX_SLIDES=36
# VIDEO_FRAME_INTERVAL_SECONDS=60
# VIDEO_SLIDE_SAMPLE_INTERVAL_SECONDS=15
# VIDEO_SLIDE_CHANGE_THRESHOLD=0.025
# VIDEO_SLIDE_MIN_GAP_SECONDS=20
# VIDEO_SLIDE_END_PADDING_SECONDS=60
# VIDEO_SLIDE_MAX_SAMPLES=360
# VIDEO_TRANSCRIPT_MERGE_GAP_SECONDS=1.2
# VIDEO_TRANSCRIPT_MIN_SEGMENT_SECONDS=15
# VIDEO_TRANSCRIPT_MAX_SEGMENT_SECONDS=45
# VIDEO_TRANSCRIPT_MIN_SEGMENT_CHARS=80
# VIDEO_TRANSCRIPT_MAX_SEGMENT_CHARS=220
# VIDEO_YTDLP_COOKIES_FROM_BROWSER=chrome
# VIDEO_REMOTE_FRAME_WINDOW_SECONDS=600
# VIDEO_REMOTE_FRAME_FORMAT=18/b[height<=360][ext=mp4]/bv*[height<=360][ext=mp4]/best[height<=360]/best
