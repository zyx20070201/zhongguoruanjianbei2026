generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

// -----------------------------------------------------------------------------
// Core Data Models
// -----------------------------------------------------------------------------

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String?  @unique
  password  String // In real app, hashed
  emailVerifiedAt DateTime?
  passwordChangedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspaces     Workspace[]
  profiles       Profile[]
  learnerStateCores LearnerStateCore[]
  conversationSessions ConversationSession[]
  conversationMessages ConversationMessage[]
  savedMemories SavedMemory[]
  authTokens AuthToken[]
}

model AuthToken {
  id        String   @id @default(uuid())
  userId    String
  type      String
  tokenHash String   @unique
  expiresAt DateTime
  consumedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, expiresAt])
}

model Workspace {
  id          String   @id @default(uuid())
  name        String // Course name
  description String? // Course description
  major       String? // Major/Direction
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workbenches        Workbench[]
  fileObjects        FileSystemObject[]
  profiles           Profile[]
  learningGoals      LearningGoal[]
  learningPlans      LearningPlan[]
  learningEvents     LearningEvent[]
  learningEventSchemas LearningEventSchemaRegistry[]
  learningEventSequencePatterns LearningEventSequencePattern[]
  learningTraces     LearningTrace[]
  knowledgeChunks    KnowledgeChunk[]
  knowledgeIndexJobs KnowledgeIndexJob[]
  courseKnowledgeConcepts CourseKnowledgeConcept[]
  courseKnowledgeConceptTags CourseKnowledgeConceptTag[]
  courseKnowledgeRelations CourseKnowledgeRelation[]
  courseKnowledgeBindings CourseKnowledgeBinding[]
  courseKnowledgeExercises CourseKnowledgeExercise[]
  courseKnowledgeExerciseBindings CourseKnowledgeExerciseBinding[]
  courseKnowledgeMisconceptions CourseKnowledgeMisconception[]
  courseKnowledgeActivations CourseKnowledgeActivation[]
  courseKnowledgeLearnerStates CourseKnowledgeLearnerState[]
  courseKnowledgeGovernanceLogs CourseKnowledgeGovernanceLog[]
  learningRuns       LearningRun[]
  studioArtifacts    StudioArtifact[]
  learnerStateCores LearnerStateCore[]
  learnerStateSignals LearnerStateSignal[]
  learnerObservations LearnerObservation[]
  learnerStateTransitions LearnerStateTransition[]
  learnerStateSnapshotVersions LearnerStateSnapshotVersion[]
  learnerEvidences   LearnerEvidence[]
  learnerMemoryControls LearnerMemoryControl[]
  workbenchTableProperties WorkbenchTableProperty[]
  workbenchTablePropertyValues WorkbenchTablePropertyValue[]
  flashcardDecks     FlashcardDeck[]
  flashcards         Flashcard[]
  flashcardReviews   FlashcardReviewLog[]
  conversationSessions ConversationSession[]
  conversationMessages ConversationMessage[]
  savedMemories SavedMemory[]

  // Extension point for AI Terminal
  aiTerminalConfig String? // JSON string or relation to a config model
}

// The unified file system abstraction
model FileSystemObject {
  id           String   @id @default(uuid())
  name         String
  nodeType     String // "file" | "folder"
  fileCategory String? // "note", "code", "document", "media", "generated", "other"
  resourceType String   @default("file") // "source" | "note" | "generated" | "artifact" | "file" | "folder"
  scope        String   @default("workspace") // "workspace" | "workbench"
  origin       String   @default("user") // "user" | "upload" | "web" | "ai" | "system" | "legacy"
  metadataJson String   @default("{}")
  tags         String   @default("[]")
  extension    String?
  size         Int?
  isBinary     Boolean  @default(false)
  path         String // Virtual path in workspace
  content      String? // Content for simple text files, or reference to S3/Local disk
  mimeType     String?
  storageKey   String? // For binary files
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  ownerWorkbenchId String?
  ownerWorkbench   Workbench? @relation("OwnedResources", fields: [ownerWorkbenchId], references: [id])

  parentId String?
  parent   FileSystemObject?  @relation("FolderChildren", fields: [parentId], references: [id])
  children FileSystemObject[] @relation("FolderChildren")

  panels             Panel[]
  resources          GeneratedResource[]
  workbenchBindings  WorkbenchResource[]
  knowledgeChunks    KnowledgeChunk[]
  knowledgeIndexJobs KnowledgeIndexJob[]
  knowledgeBindings  CourseKnowledgeBinding[]
  courseKnowledgeExercises CourseKnowledgeExercise[]
  flashcardDecks     FlashcardDeck[]
  studioArtifacts    StudioArtifact[]

  @@unique([workspaceId, path])
  @@index([workspaceId, resourceType, updatedAt])
  @@index([workspaceId, scope, updatedAt])
  @@index([ownerWorkbenchId, resourceType, updatedAt])
}

// Workbench: Task-oriented container
model Workbench {
  id           String    @id @default(uuid())
  name         String // Task name (e.g. "Chapter 1 Notes")
  title        String    @default("")
  description  String    @default("")
  rootPath     String?
  layout       String? // JSON string representing layout (e.g. grid layout config)
  stateJson    String?
  lastOpenedAt DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  panels         Panel[]
  learningGoalId String?
  learningGoal   LearningGoal?   @relation(fields: [learningGoalId], references: [id])
  learningEvents LearningEvent[]
  learningEventSequencePatterns LearningEventSequencePattern[]
  learningTraces LearningTrace[]
  learningPlans  LearningPlan[]
  knowledgeBindings CourseKnowledgeBinding[]
  flashcardDecks FlashcardDeck[]
  flashcards     Flashcard[]
  ownedResources FileSystemObject[] @relation("OwnedResources")
  resourceBindings WorkbenchResource[]
  learnerEvidences LearnerEvidence[]
  learnerStateTransitions LearnerStateTransition[]
  learnerMemoryControls LearnerMemoryControl[]
  tablePropertyValues WorkbenchTablePropertyValue[]
  conversationSessions ConversationSession[]
  conversationMessages ConversationMessage[]
  savedMemories SavedMemory[]
  studioArtifacts StudioArtifact[]

  // Extension point for local AI Assistant
  aiAssistantContext String? // JSON string capturing task context
}

model WorkbenchTableProperty {
  id          String   @id @default(uuid())
  workspaceId String
  name        String
  type        String
  source      String   @default("custom") // "system" | "custom"
  visible     Boolean  @default(true)
  orderIndex  Int      @default(0)
  widthPx     Int      @default(220)
  optionsJson String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  values    WorkbenchTablePropertyValue[]

  @@unique([workspaceId, name])
  @@index([workspaceId, orderIndex])
}

model WorkbenchTablePropertyValue {
  id          String   @id @default(uuid())
  workspaceId String
  workbenchId String
  propertyId  String
  valueJson   String   @default("null")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workbench Workbench @relation(fields: [workbenchId], references: [id], onDelete: Cascade)
  property  WorkbenchTableProperty @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([workbenchId, propertyId])
  @@index([workspaceId, propertyId])
}

// Resource-level membership for workbench context. FileSystemObject remains the
// storage/preview/indexing carrier during the migration away from folder trees.
model WorkbenchResource {
  id          String   @id @default(uuid())
  role        String   @default("resource") // "source" | "note" | "generated" | "artifact" | "resource"
  source      String   @default("local") // "local" | "shared" | "copied" | "generated" | "uploaded"
  pinned      Boolean  @default(false)
  orderIndex  Int      @default(0)
  metadataJson String  @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workbenchId String
  workbench   Workbench @relation(fields: [workbenchId], references: [id])

  fileObjectId String
  fileObject   FileSystemObject @relation(fields: [fileObjectId], references: [id])

  @@unique([workbenchId, fileObjectId, role])
  @@index([workbenchId, role, updatedAt])
  @@index([fileObjectId])
}

model StudioArtifact {
  id                 String   @id @default(uuid())
  artifactKey        String
  title              String
  summary            String   @default("")
  status             String   @default("ready")
  goal               String
  templateId         String
  templateVersion    String
  generatorKind      String
  generatorVersion   String
  renderer           String
  schemaVersion      String
  source             String   @default("unknown")
  structuredJson     String   @default("{}")
  renderedContent    String   @default("")
  sourceRefsJson     String   @default("[]")
  reviewJson         String   @default("{}")
  recommendationJson String   @default("{}")
  workflowTraceJson  String   @default("[]")
  metadataJson       String   @default("{}")
  parentArtifactId   String?
  derivedFromJson    String   @default("[]")
  usageStatsJson     String   @default("{}")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id], onDelete: SetNull)

  fileObjectId String?
  fileObject   FileSystemObject? @relation(fields: [fileObjectId], references: [id], onDelete: SetNull)

  runId String?

  @@unique([workspaceId, artifactKey])
  @@index([workspaceId, goal, updatedAt])
  @@index([workspaceId, templateId, updatedAt])
  @@index([workbenchId, updatedAt])
  @@index([fileObjectId])
}

// Panel: Interactive unit referencing file objects
model Panel {
  id         String   @id @default(uuid())
  title      String? // Title of the panel
  panelType  String // "file-preview-panel", "note-editor-panel", "code-editor-panel", "ai-assistant-panel"
  config     String? // JSON string for panel specific settings
  layoutInfo String? // Layout placement info
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  workbenchId String
  workbench   Workbench @relation(fields: [workbenchId], references: [id])

  // Optional reference to a file system object
  fileObjectId String?
  fileObject   FileSystemObject? @relation(fields: [fileObjectId], references: [id])
}

// Profile: Guides resource generation and recommendation
model Profile {
  id          String   @id @default(uuid())
  name        String
  preferences String // JSON string
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id])

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id])
}

// Generated Resource: Results from AI
model GeneratedResource {
  id        String   @id @default(uuid())
  prompt    String?
  status    String // "PENDING", "COMPLETED", "FAILED"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fileObjectId String?
  fileObject   FileSystemObject? @relation(fields: [fileObjectId], references: [id])
}

// Goal-oriented learning state used by the orchestration layer.
model LearningGoal {
  id             String   @id @default(uuid())
  title          String
  goalText       String
  skillsJson     String   @default("[]")
  weaknessesJson String   @default("[]")
  mode           String   @default("quick-start")
  status         String   @default("active")
  planJson       String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenches Workbench[]
  plans       LearningPlan[]
  events      LearningEvent[]
  traces      LearningTrace[]
  knowledgeBindings CourseKnowledgeBinding[]
}

model LearningPlan {
  id                   String   @id @default(uuid())
  scope                String   @default("goal")
  status               String   @default("active")
  version              Int      @default(1)
  objective            String
  rationale            String   @default("")
  assumptionsJson      String   @default("[]")
  constraintsJson      String   @default("[]")
  targetSkillsJson     String   @default("[]")
  weakSkillsJson       String   @default("[]")
  milestonesJson       String   @default("[]")
  stepsJson            String   @default("[]")
  adaptationPolicyJson String   @default("{}")
  evidenceJson         String   @default("{}")
  diagnosticReportJson String   @default("{}")
  candidateResourcesJson String @default("[]")
  knowledgeGraphSnapshotJson String @default("{}")
  reflectionHistoryJson String  @default("[]")
  constraintScoresJson String   @default("{}")
  revisionCount        Int      @default(0)
  nextStepId           String?
  previousPlanId       String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  goalId String?
  goal   LearningGoal? @relation(fields: [goalId], references: [id])

  previousPlan LearningPlan?  @relation("LearningPlanVersions", fields: [previousPlanId], references: [id])
  nextVersions LearningPlan[] @relation("LearningPlanVersions")

  @@index([workspaceId, status, updatedAt])
  @@index([goalId, status, version])
  @@index([workbenchId, status, updatedAt])
}

model CourseKnowledgeConcept {
  id            String   @id @default(uuid())
  conceptKey    String
  title         String
  description   String   @default("")
  aliasesJson   String   @default("[]")
  category      String   @default("concept")
  difficulty    Float    @default(0.5)
  status        String   @default("active")
  source        String   @default("system")
  evidenceJson  String   @default("{}")
  activationScore Float  @default(0)
  lastActivatedAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  outgoingRelations CourseKnowledgeRelation[] @relation("KnowledgeRelationFrom")
  incomingRelations CourseKnowledgeRelation[] @relation("KnowledgeRelationTo")
  bindings          CourseKnowledgeBinding[]
  exerciseBindings  CourseKnowledgeExerciseBinding[]
  misconceptions    CourseKnowledgeMisconception[]
  activations       CourseKnowledgeActivation[]
  learnerStates     CourseKnowledgeLearnerState[]
  tags              CourseKnowledgeConceptTag[]

  @@unique([workspaceId, conceptKey])
  @@index([workspaceId, status, updatedAt])
  @@index([workspaceId, activationScore])
}

model CourseKnowledgeConceptTag {
  id              String   @id @default(uuid())
  label           String
  normalizedLabel String
  state           String   @default("candidate")
  sourcesJson     String   @default("[]")
  rationale       String   @default("")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, conceptId, normalizedLabel])
  @@index([workspaceId, state, normalizedLabel])
  @@index([conceptId, state])
}

model CourseKnowledgeRelation {
  id             String   @id @default(uuid())
  relationType   String
  weight         Float    @default(0.6)
  confidence     Float    @default(0.55)
  source         String   @default("system")
  evidenceJson   String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  fromConceptId String
  fromConcept   CourseKnowledgeConcept @relation("KnowledgeRelationFrom", fields: [fromConceptId], references: [id], onDelete: Cascade)

  toConceptId String
  toConcept   CourseKnowledgeConcept @relation("KnowledgeRelationTo", fields: [toConceptId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, fromConceptId, toConceptId, relationType])
  @@index([workspaceId, relationType])
  @@index([toConceptId, relationType])
}

model CourseKnowledgeBinding {
  id             String   @id @default(uuid())
  bindingType    String
  targetType     String
  targetId       String
  role           String   @default("supports")
  strength       Float    @default(0.55)
  confidence     Float    @default(0.55)
  evidenceJson   String   @default("{}")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  fileObjectId String?
  fileObject   FileSystemObject? @relation(fields: [fileObjectId], references: [id], onDelete: SetNull)

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id], onDelete: SetNull)

  goalId String?
  goal   LearningGoal? @relation(fields: [goalId], references: [id], onDelete: SetNull)

  @@unique([workspaceId, conceptId, targetType, targetId, role])
  @@index([workspaceId, targetType, targetId])
  @@index([conceptId, bindingType])
}

model CourseKnowledgeExercise {
  id           String   @id @default(uuid())
  exerciseKey  String
  title        String
  prompt       String   @default("")
  exerciseType String   @default("question")
  difficulty   Float    @default(0.5)
  answerJson   String   @default("{}")
  explanation  String   @default("")
  source       String   @default("ai_kg_extraction")
  evidenceJson String   @default("{}")
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  fileObjectId String?
  fileObject   FileSystemObject? @relation(fields: [fileObjectId], references: [id], onDelete: SetNull)

  bindings CourseKnowledgeExerciseBinding[]

  @@unique([workspaceId, exerciseKey])
  @@index([workspaceId, status, updatedAt])
  @@index([fileObjectId])
}

model CourseKnowledgeExerciseBinding {
  id          String   @id @default(uuid())
  role        String   @default("assesses")
  strength    Float    @default(0.65)
  confidence  Float    @default(0.65)
  evidenceJson String  @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  exerciseId String
  exercise   CourseKnowledgeExercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, exerciseId, conceptId, role])
  @@index([conceptId, role])
  @@index([exerciseId])
}

model CourseKnowledgeMisconception {
  id              String   @id @default(uuid())
  misconceptionKey String
  title           String
  description     String   @default("")
  repairHint      String   @default("")
  severity        Float    @default(0.5)
  confidence      Float    @default(0.55)
  evidenceJson    String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, conceptId, misconceptionKey])
  @@index([workspaceId, severity])
}

model CourseKnowledgeActivation {
  id             String   @id @default(uuid())
  activationType String
  sourceType     String
  sourceId       String?
  score          Float    @default(0.4)
  evidenceJson   String   @default("{}")
  activatedAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@index([workspaceId, activatedAt])
  @@index([conceptId, activatedAt])
  @@index([sourceType, sourceId])
}

model CourseKnowledgeLearnerState {
  id                 String   @id @default(uuid())
  stateScope         String   @default("workspace")
  masteryEstimate    Float    @default(0.5)
  weaknessEstimate   Float    @default(0.3)
  readinessEstimate  Float    @default(0.5)
  evidenceJson       String   @default("{}")
  sourceSignalIdsJson String  @default("[]")
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  conceptId String
  concept   CourseKnowledgeConcept @relation(fields: [conceptId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, conceptId, stateScope])
  @@index([workspaceId, readinessEstimate])
  @@index([workspaceId, weaknessEstimate])
  @@index([conceptId, updatedAt])
}

model CourseKnowledgeGovernanceLog {
  id            String   @id @default(uuid())
  action        String
  status        String   @default("completed")
  targetType    String
  targetId      String?
  beforeJson    String   @default("{}")
  afterJson     String   @default("{}")
  rationale     String   @default("")
  confidence    Float    @default(0.55)
  createdAt     DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, action, createdAt])
  @@index([targetType, targetId])
}

// Append-only-ish event stream for learner actions, agent actions and generated artifacts.
model LearningEvent {
  id           String   @id @default(uuid())
  eventType    String
  actor        String   @default("system")
  schemaVersion String  @default("learning_event.v2")
  eventFamily  String   @default("unknown")
  objectType   String?
  objectId     String?
  sessionId    String?
  idempotencyKey String? @unique
  payloadJson  String   @default("{}")
  metadataJson String   @default("{}")
  cognitiveSignalsJson String @default("[]")
  diagnosticFeaturesJson String @default("{}")
  qualityJson  String   @default("{}")
  confidence   Float    @default(0.58)
  observedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  goalId String?
  goal   LearningGoal? @relation(fields: [goalId], references: [id])

  @@index([workspaceId, observedAt])
  @@index([workspaceId, eventType, observedAt])
  @@index([workspaceId, eventFamily, observedAt])
  @@index([workspaceId, actor, observedAt])
  @@index([objectType, objectId])
}

model LearningEventSchemaRegistry {
  id              String   @id @default(uuid())
  schemaKey       String
  version         String
  status          String   @default("active")
  scope           String   @default("global")
  description     String   @default("")
  sourceFramework String   @default("")
  eventFamiliesJson String @default("[]")
  dialogueActsJson String @default("[]")
  cognitiveSignalsJson String @default("[]")
  schemaJson      String   @default("{}")
  governanceJson  String   @default("{}")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String?
  workspace   Workspace? @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([schemaKey, version, workspaceId])
  @@index([status, updatedAt])
  @@index([workspaceId, status])
}

model LearningEventSequencePattern {
  id                String   @id @default(uuid())
  patternKey        String
  patternType       String
  status            String   @default("active")
  eventIdsJson      String   @default("[]")
  involvedConceptsJson String @default("[]")
  signalSummaryJson String   @default("{}")
  windowStart       DateTime
  windowEnd         DateTime
  confidence        Float    @default(0.5)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id], onDelete: SetNull)

  goalId String?

  @@unique([workspaceId, patternKey])
  @@index([workspaceId, patternType, updatedAt])
  @@index([workspaceId, status, updatedAt])
  @@index([workbenchId, updatedAt])
}

// Condensed memory extracted from events and workbench activity.
model LearningTrace {
  id              String   @id @default(uuid())
  summary         String
  masteryJson     String   @default("{}")
  nextActionsJson String   @default("[]")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  goalId String?
  goal   LearningGoal? @relation(fields: [goalId], references: [id])
}

model ConversationSession {
  id           String   @id @default(uuid())
  workspaceId  String
  workbenchId  String?
  userId       String
  title        String   @default("")
  source       String   @default("terminal")
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workbench Workbench? @relation(fields: [workbenchId], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages  ConversationMessage[]

  @@index([workspaceId, updatedAt])
  @@index([userId, updatedAt])
}

model ConversationMessage {
  id           String   @id @default(uuid())
  sessionId    String
  workspaceId  String
  workbenchId  String?
  userId       String
  role         String
  content      String
  contentHash  String
  metadataJson String   @default("{}")
  createdAt    DateTime @default(now())

  session   ConversationSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  workspace Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workbench Workbench?           @relation(fields: [workbenchId], references: [id], onDelete: SetNull)
  user      User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([sessionId, contentHash])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, workbenchId, createdAt])
  @@index([userId, createdAt])
}

model SavedMemory {
  id                  String   @id @default(uuid())
  workspaceId          String
  workbenchId          String?
  userId               String
  memoryKey            String
  text                 String
  category             String   @default("preference")
  source               String   @default("explicit_user_request")
  confidence           Float    @default(0.9)
  status               String   @default("active")
  createdFromMessageId String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  workbench Workbench? @relation(fields: [workbenchId], references: [id], onDelete: SetNull)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, memoryKey])
  @@index([workspaceId, status, updatedAt])
}

// Searchable grounding units derived from workspace files and generated resources.
model KnowledgeChunk {
  id            String   @id @default(uuid())
  chunkIndex    Int
  text          String
  summary       String?
  metadataJson  String   @default("{}")
  tokenEstimate Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  fileObjectId String
  fileObject   FileSystemObject @relation(fields: [fileObjectId], references: [id])

  @@unique([fileObjectId, chunkIndex])
  @@index([workspaceId, fileObjectId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model KnowledgeChunkTerm {
  workspaceId    String
  fileObjectId  String
  chunkId       String
  term          String
  termFrequency Int      @default(0)
  fieldWeight   Float    @default(1)
  updatedAt     DateTime @default(now())

  @@id([chunkId, term])
  @@index([workspaceId, term])
  @@index([workspaceId, fileObjectId, term])
  @@index([workspaceId, fileObjectId])
}

model KnowledgeIndexJob {
  id           String    @id @default(uuid())
  status       String    @default("pending")
  extractor    String?
  errorMessage String?
  chunkCount   Int       @default(0)
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  fileObjectId String
  fileObject   FileSystemObject @relation(fields: [fileObjectId], references: [id])

  @@index([workspaceId, status])
  @@index([fileObjectId])
}

model LearningRun {
  id           String   @id @default(uuid())
  intent       String
  status       String   @default("pending")
  inputJson    String   @default("{}")
  resultJson   String   @default("{}")
  errorMessage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  goalId      String?

  steps LearningRunStep[]

  @@index([workspaceId, status])
}

// Central learner-state core. The old monolithic LearnerState JSON table is
// intentionally replaced by normalized layers: stable signals, working signals,
// short-term observations, transitions, and snapshot versions.
model LearnerStateCore {
  id                 String   @id @default(uuid())
  scope              String   @default("workspace")
  version            Int      @default(1)
  summary            String   @default("")
  governanceJson     String   @default("{}")
  currentPositionJson String  @default("{}")
  lastEvidenceAt     DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  signals      LearnerStateSignal[]
  observations LearnerObservation[]
  transitions  LearnerStateTransition[]
  versions     LearnerStateSnapshotVersion[]

  @@unique([workspaceId, scope])
  @@index([userId, updatedAt])
  @@index([workspaceId, updatedAt])
}

model LearnerStateSignal {
  id              String   @id @default(uuid())
  signalKey       String
  layer           String
  dimension       String
  label           String
  value           String
  confidence      Float    @default(0.5)
  status          String   @default("candidate")
  evidenceIdsJson String   @default("[]")
  sourcesJson     String   @default("[]")
  rationale       String   @default("")
  firstObservedAt DateTime?
  lastObservedAt  DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  learnerStateCoreId String
  learnerStateCore   LearnerStateCore @relation(fields: [learnerStateCoreId], references: [id], onDelete: Cascade)

  @@unique([learnerStateCoreId, signalKey])
  @@index([workspaceId, layer, dimension])
  @@index([workspaceId, status, updatedAt])
}

model LearnerObservation {
  id              String   @id @default(uuid())
  observationKey  String
  dimension       String
  label           String
  value           String
  confidence      Float    @default(0.4)
  status          String   @default("active")
  evidenceIdsJson String   @default("[]")
  sourcesJson     String   @default("[]")
  rationale       String   @default("")
  observedAt      DateTime @default(now())
  expiresAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  learnerStateCoreId String
  learnerStateCore   LearnerStateCore @relation(fields: [learnerStateCoreId], references: [id], onDelete: Cascade)

  @@unique([learnerStateCoreId, observationKey])
  @@index([workspaceId, status, observedAt])
  @@index([workspaceId, dimension, observedAt])
}

model LearnerStateSnapshotVersion {
  id              String   @id @default(uuid())
  version         Int
  snapshotJson    String   @default("{}")
  summary         String   @default("")
  changedBy       String   @default("system")
  changeReason    String   @default("")
  transitionIdsJson String @default("[]")
  evidenceIdsJson String   @default("[]")
  confidenceJson  String   @default("{}")
  createdAt       DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  learnerStateCoreId String
  learnerStateCore   LearnerStateCore @relation(fields: [learnerStateCoreId], references: [id], onDelete: Cascade)

  @@unique([learnerStateCoreId, version])
  @@index([workspaceId, createdAt])
}

model LearnerEvidence {
  id           String   @id @default(uuid())
  evidenceType String
  sourceType   String
  sourceId     String?
  actor        String   @default("system")
  title        String   @default("")
  summary      String   @default("")
  payloadJson  String   @default("{}")
  confidence   Float    @default(0.6)
  observedAt   DateTime @default(now())
  createdAt    DateTime @default(now())

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  goalId String?

  transitions LearnerStateTransition[]

  @@index([workspaceId, observedAt])
  @@index([workspaceId, evidenceType, observedAt])
  @@index([sourceType, sourceId])
}

model LearnerStateTransition {
  id              String   @id @default(uuid())
  status          String   @default("pending")
  proposedBy      String   @default("system")
  targetDimension String
  operation       String
  confidence      Float    @default(0.6)
  payloadJson     String   @default("{}")
  rationale       String   @default("")
  appliedVersion  Int?
  createdAt       DateTime @default(now())
  appliedAt       DateTime?

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  learnerStateCoreId String?
  learnerStateCore   LearnerStateCore? @relation(fields: [learnerStateCoreId], references: [id], onDelete: SetNull)

  evidenceId String?
  evidence   LearnerEvidence? @relation(fields: [evidenceId], references: [id], onDelete: SetNull)

  @@index([workspaceId, status, createdAt])
  @@index([learnerStateCoreId, status])
  @@index([evidenceId])
}

model LearnerMemoryControl {
  id              String   @id @default(uuid())
  workspaceId     String
  workbenchId     String?
  memoryKey       String
  dimension       String
  action          String
  status          String   @default("active")
  originalText    String   @default("")
  correctedText   String   @default("")
  reason          String   @default("")
  weightMultiplier Float   @default(1)
  createdBy       String   @default("user")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id])
  workbench Workbench? @relation(fields: [workbenchId], references: [id])

  @@index([workspaceId, status])
  @@index([workspaceId, memoryKey])
  @@index([workspaceId, dimension])
}

model LearningRunStep {
  id           String    @id @default(uuid())
  capability   String
  status       String    @default("pending")
  inputJson    String    @default("{}")
  outputJson   String    @default("{}")
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  runId String
  run   LearningRun @relation(fields: [runId], references: [id])

  @@index([runId, status])
}

// Source-grounded flashcard decks generated or curated inside a workbench.
model FlashcardDeck {
  id              String   @id @default(uuid())
  title           String
  description     String   @default("")
  source          String   @default("ai_studio")
  sourceFileIds   String   @default("[]")
  sourceRefsJson  String   @default("[]")
  settingsJson    String   @default("{}")
  generationRunId String?
  fileObjectId    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  fileObject FileSystemObject? @relation(fields: [fileObjectId], references: [id])
  cards      Flashcard[]

  @@index([workspaceId, updatedAt])
  @@index([workbenchId])
}

model Flashcard {
  id                String   @id @default(uuid())
  front             String
  back              String
  cardType          String   @default("basic")
  difficulty        String   @default("medium")
  concept           String   @default("")
  explanation       String   @default("")
  tagsJson          String   @default("[]")
  sourceRefsJson    String   @default("[]")
  metadataJson      String   @default("{}")
  orderIndex        Int      @default(0)
  reviewCount       Int      @default(0)
  lapseCount        Int      @default(0)
  dueAt             DateTime @default(now())
  lastReviewedAt    DateTime?
  stability         Float    @default(0)
  retrievability    Float    @default(1)
  fsrsDifficulty    Float    @default(5)
  state             String   @default("new")
  suspended         Boolean  @default(false)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  workbenchId String?
  workbench   Workbench? @relation(fields: [workbenchId], references: [id])

  deckId String
  deck   FlashcardDeck @relation(fields: [deckId], references: [id], onDelete: Cascade)

  reviews FlashcardReviewLog[]

  @@index([workspaceId, dueAt])
  @@index([deckId, orderIndex])
  @@index([workbenchId])
}

model FlashcardReviewLog {
  id                     String   @id @default(uuid())
  rating                 String
  elapsedMs              Int      @default(0)
  previousState          String
  nextState              String
  previousDueAt          DateTime?
  nextDueAt              DateTime
  previousStability      Float    @default(0)
  nextStability          Float    @default(0)
  previousDifficulty     Float    @default(5)
  nextDifficulty         Float    @default(5)
  previousRetrievability Float    @default(1)
  nextRetrievability     Float    @default(1)
  reviewedAt             DateTime @default(now())
  metadataJson           String   @default("{}")

  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  cardId String
  card   Flashcard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([workspaceId, reviewedAt])
  @@index([cardId, reviewedAt])
}
